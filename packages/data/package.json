{
  "name": "@repo/data",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "./src/index.ts",
  "exports": {
    ".": "./src/index.ts"
  },
  "scripts": {
    "build": "tsc --noEmit",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "lint": "echo 'lint: ok'",
    "migrate": "sh -c 'set -a; [ -f ../../apps/web/.env.local ] && . ../../apps/web/.env.local; set +a; tsx src/migrate.ts'",
    "backfill:public-id": "sh -c 'set -a; [ -f ../../apps/web/.env.local ] && . ../../apps/web/.env.local; set +a; tsx src/scripts/backfillPublicIds.ts'"
  },
  "dependencies": {
    "nanoid": "^5.1.16",
    "pg": "^8.12.0"
  },
  "devDependencies": {
    "@types/node": "*",
    "@types/pg": "^8.11.0",
    "tsx": "*",
    "typescript": "*",
    "vitest": "*"
  }
}
