# .env.example — 复制为 .env 后按需改。骨架默认值与 infra/docker-compose.yml 对齐。
DATABASE_URL=postgresql://boardx:boardx@localhost:5432/boardx
REDIS_URL=redis://localhost:6379

# web 调用 worker/data 时用到；默认本地。
WEB_PORT=3000

# CAP-COLLAB WebSocket sidecar gateway（Playwright / 本地调试用）。
COLLAB_WS_PORT=3001

# CAP-FILE（p10 知识库）对象存储：本地 MinIO，S3 API 兼容。生产换真实 S3 端点/凭据即可。
S3_ENDPOINT=http://localhost:9090
S3_REGION=us-east-1
S3_ACCESS_KEY=boardx
S3_SECRET_KEY=boardx123
S3_BUCKET=boardx-kb
S3_FORCE_PATH_STYLE=true

# CAP-PAYMENT webhook 回调共享密钥（F05 / p14 支付引擎）。
# /api/payment/webhook 用它做 fail-closed 校验——未设置或不匹配一律拒绝，
# 防止任何人靠猜 orderId 伪造"支付成功"回调。见 apps/web/lib/webhook-auth.ts。
# 生产环境务必换成真实网关签发的密钥，不能用这个占位默认值。
WEBHOOK_SECRET=dev-only-change-me
