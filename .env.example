# .env.example — 复制为 .env 后按需改。骨架默认值与 infra/docker-compose.yml 对齐。
DATABASE_URL=postgresql://boardx:boardx@localhost:5432/boardx
REDIS_URL=redis://localhost:6379

# web 调用 worker/data 时用到；默认本地。
WEB_PORT=3000

# CAP-PAYMENT（F05）：支付网关 webhook 回调的共享密钥。
# /api/payment/webhook 用它做 fail-closed 校验——未设置或不匹配一律拒绝，
# 防止任何人靠猜 orderId 伪造"支付成功"回调。生产环境务必换成真实网关签发的密钥。
WEBHOOK_SECRET=dev-only-change-me
